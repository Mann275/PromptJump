{
  "name": "PromptJump",
  "version": "3.0",
  "manifest_version": 3,
  "description": "PromptJump — jump to your prompts in active chat sessions on ChatGPT, Claude.",
  "icons": {
    "16": "icons/logo-16.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["https://chatgpt.com/*", "https://claude.ai/*"],
  "web_accessible_resources": [
    {
      "resources": [
        "chat-manager.js",
        "xhr-tracker.js",
        "api-tracker.js",
        "platform-detector.js"
      ],
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"],
      "js": ["platform-detector.js", "main-script.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/logo-16.png",
      "48": "icons/logo-48.png",
      "128": "icons/logo-128.png"
    },
    "default_title": "PromptJump",
    "default_popup": "popup.html"
  }
}
